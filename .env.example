# Local Development Environment Keys (With VITE_ prefix for client bundle access)
VITE_GROQ_API_KEY="your_groq_api_key_here"
VITE_GEMINI_API_KEY="your_gemini_api_key_here"
VITE_OPENAI_API_KEY="your_openai_api_key_here"
VITE_DEEPSEEK_API_KEY="your_deepseek_api_key_here"

# Hugging Face Spaces Production Environment Keys (Declare on Space Settings > Secrets without VITE_)
# These are dynamically compiled into window.env at runtime on container startup!
GROQ_API_KEY="production_groq_api_key_here"
GEMINI_API_KEY="production_gemini_api_key_here"
OPENAI_API_KEY="production_openai_api_key_here"
DEEPSEEK_API_KEY="production_deepseek_api_key_here"

# General Service Config
APP_URL="http://localhost:7860"
